# ─────────────────────────────────────────────────────────────────────────────
# job-agent environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — used to power the filtering, tailoring, and cover-letter
# generation agents via the Claude API.
# Get yours at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# Notion integration token — grants the agent write access to your workspace
# so it can create and update job-listing pages.
# Create an internal integration at: https://www.notion.so/my-integrations
NOTION_TOKEN=

# The Notion page ID that will become the parent of the job-listing database.
# Open the page in Notion, click Share → Copy link, and grab the 32-char hex
# ID from the URL (e.g. https://notion.so/My-Page-<ID>?...).
NOTION_PARENT_PAGE_ID=
